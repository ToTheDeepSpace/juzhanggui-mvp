JZG_WECHAT_OPEN_APP_ID=微信开放平台网站应用AppID
JZG_WECHAT_OPEN_APP_SECRET=微信开放平台网站应用AppSecret
JZG_WECHAT_REDIRECT_URI=https://jusichen.com/api/player/wechat/callback

# 前端
