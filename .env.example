# 默认店铺 ID
DEFAULT_TENANT_ID=你的_tenant_id

# JWT 密钥（生产环境务必更换为随机字符串）
JWT_SECRET=随机生成的密钥字符串

# 手机短信验证码（腾讯云短信）
# 未配置完整短信参数时，剧司辰会保留手机号+昵称临时登录；配置齐后自动强制短信验证码。
AUTH_CODE_PEPPER=随机生成的验证码哈希盐
SMS_CODE_TTL_MINUTES=5
SMS_CODE_COOLDOWN_SECONDS=60
TENCENTCLOUD_SECRET_ID=你的腾讯云SecretId
TENCENTCLOUD_SECRET_KEY=你的腾讯云SecretKey
TENCENT_SMS_REGION=ap-guangzhou
TENCENT_SMS_SDK_APP_ID=短信应用SdkAppId
TENCENT_SMS_SIGN_NAME=已审核通过的短信签名内容
TENCENT_SMS_TEMPLATE_ID=已审核通过的验证码模板ID

# 微信开放平台网站应用扫码登录（剧司辰玩家中心）
